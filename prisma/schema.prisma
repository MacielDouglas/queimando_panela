generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Recipe {
  id                String             @id @default(cuid())
  slug              String             @unique
  title             String
  summary           String?
  story             String?
  modeOfPreparation String?
  difficulty        RecipeDifficulty
  prepTimeMinutes   Int?
  cookTimeMinutes   Int?
  servings          Int?
  suggestions       String?
  notesAuthor       String?
  notesPublic       String?
  nutritionSummary  String?
  nutritionPer100g  Json?
  classification    Json?
  isPublished       Boolean            @default(false)
  publishedAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  authorId          String
  author            User               @relation(fields: [authorId], references: [id], onDelete: Cascade)

  sections          RecipeSection[]
  ingredients       Ingredient[]
  utensils          UtensilOnRecipe[]
  images            RecipeImage[]
  comments          Comment[]
  recipeTypes       RecipeTypeOnRecipe[]

  @@index([authorId])
}

model RecipeSection {
  id                String        @id @default(cuid())

  recipeId          String
  recipe            Recipe        @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  name              String
  ingredientsText   String?       @db.Text
  modeOfPreparation String        @db.Text
  order             Int

  ingredients       Ingredient[]

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@unique([recipeId, order])
  @@index([recipeId])
  @@index([recipeId, order])
}

model Ingredient {
  id                  String              @id @default(cuid())

  recipeId            String
  recipe              Recipe              @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  sectionId           String?
  section             RecipeSection?      @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  generalIngredientId String?
  generalIngredient   GeneralIngredient?  @relation(fields: [generalIngredientId], references: [id], onDelete: SetNull)

  amount              String?
  unit                String?
  name                String
  originalText        String              @db.Text
  order               Int

  createdAt           DateTime            @default(now())

  @@index([recipeId])
  @@index([sectionId])
  @@index([generalIngredientId])
  @@index([recipeId, order])
  @@index([sectionId, order])
}

model GeneralIngredient {
  id          String        @id @default(cuid())
  name        String        @unique
  createdAt   DateTime      @default(now())

  ingredients Ingredient[]
}

model RecipeType {
  id        String             @id @default(cuid())
  name      String             @unique
  createdAt DateTime           @default(now())

  recipes   RecipeTypeOnRecipe[]
}

model RecipeTypeOnRecipe {
  recipeId     String
  recipeTypeId String

  recipe       Recipe      @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeType   RecipeType  @relation(fields: [recipeTypeId], references: [id])

  createdAt    DateTime    @default(now())

  @@id([recipeId, recipeTypeId])
  @@index([recipeTypeId])
}

/// Imagens da receita (capa + galeria)
model RecipeImage {
  id String @id @default(cuid())

  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  key         String  @unique
  url         String
  alt         String
  contentType String?
  sizeBytes   Int?
  width       Int?
  height      Int?

  isCover Boolean @default(false)
  order   Int     @default(0)

  createdAt DateTime @default(now())

  @@index([recipeId])
  @@index([recipeId, isCover])
  @@index([recipeId, order])
}

/// Utensílios (tabela de referência)
model Utensil {
  id   String @id @default(cuid())
  name String @unique

  recipes UtensilOnRecipe[]

  createdAt DateTime @default(now())
}

/// Tabela de junção N:N entre Recipe e Utensil
model UtensilOnRecipe {
  recipeId  String
  utensilId String

  recipe  Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  utensil Utensil @relation(fields: [utensilId], references: [id])

  createdAt DateTime @default(now())

  @@id([recipeId, utensilId])
  @@index([utensilId])
}

/// Comentários / notas dos usuários
model Comment {
  id String @id @default(cuid())

  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  userId String?
  rating Int?
  title  String?
  body   String  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([recipeId])
  @@index([userId])
}

enum RecipeDifficulty {
  EASY
  EASY_MEDIUM
  MEDIUM
  MEDIUM_HARD
  HARD
}

model User {
  id            String   @id
  name          String
  email         String
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions Session[]
  accounts Account[]

  recipes Recipe[] // <- ADICIONE

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
