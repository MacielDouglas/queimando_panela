generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

model Recipe {
  id                String   @id @default(uuid()) @db.Uuid
  slug              String   @unique @db.VarChar(150)
  title             String   @db.VarChar(180)
  summary           String?  @db.VarChar(500)
  story             String?  @db.Text
  modeOfPreparation String?  @db.Text

  difficulty        RecipeDifficulty
  prepTimeMinutes   Int?
  cookTimeMinutes   Int?
  servings          Int?

  suggestions       String?  @db.Text
  notesAuthor       String?  @db.Text
  notesPublic       String?  @db.Text

  nutritionSummary  String?  @db.Text
  nutritionPer100g  Json?

  // Onde é mais consumida no Brasil
  consumptionSummary String? @db.Text

  // Texto de origem histórica/cultural da receita
  originSummary      String? @db.Text

  isPublished        Boolean  @default(false)
  publishedAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  authorId           String   @db.Uuid
  author             User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  classificationId   String?  @db.Uuid
  classification     RecipeClassification? @relation(fields: [classificationId], references: [id], onDelete: SetNull)

  worldOriginId      String?  @db.Uuid
  worldOrigin        WorldOrigin? @relation(fields: [worldOriginId], references: [id], onDelete: SetNull)

  sections           RecipeSection[]
  ingredients        Ingredient[]
  utensils           UtensilOnRecipe[]
  images             RecipeImage[]
  comments           Comment[]
  recipeTypes        RecipeTypeOnRecipe[]

  steps              RecipeStep[]

  @@index([authorId])
  @@index([classificationId])
  @@index([worldOriginId])
  @@index([isPublished, publishedAt])
  @@index([difficulty])
  @@index([createdAt])
}

model RecipeStep {
  id        String   @id @default(uuid()) @db.Uuid
  recipeId  String   @db.Uuid
  sectionId String?  @db.Uuid

  recipe    Recipe        @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  section   RecipeSection? @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  order     Int
  text      String  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([recipeId])
  @@index([sectionId])
  @@index([recipeId, order])
  @@index([sectionId, order])
}

model RecipeSection {
  id                String   @id @default(uuid()) @db.Uuid
  recipeId          String   @db.Uuid
  recipe            Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  name              String
  ingredientsText   String? @db.Text
  modeOfPreparation String   @db.Text
  order             Int

  ingredients       Ingredient[]
  steps             RecipeStep[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([recipeId, order])
  @@index([recipeId])
  @@index([recipeId, order])
}

model RecipeClassification {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recipes   Recipe[]

  @@index([name])
}

model WorldOrigin {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recipes   Recipe[]

  @@index([name])
}

model Ingredient {
  id                  String             @id @default(uuid()) @db.Uuid

  recipeId            String             @db.Uuid
  recipe              Recipe             @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  sectionId           String?            @db.Uuid
  section             RecipeSection?     @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  generalIngredientId String?            @db.Uuid
  generalIngredient   GeneralIngredient? @relation(fields: [generalIngredientId], references: [id], onDelete: SetNull)

  measurementUnitId   String?            @db.Uuid
  measurementUnit     MeasurementUnit?   @relation(fields: [measurementUnitId], references: [id], onDelete: SetNull)

  amount              String?
  unitText            String?
  name                String
  originalText        String             @db.Text
  order               Int

  createdAt           DateTime           @default(now())

  @@index([recipeId])
  @@index([sectionId])
  @@index([generalIngredientId])
  @@index([measurementUnitId])
  @@index([recipeId, order])
  @@index([sectionId, order])
}

model MeasurementUnit {
  id           String       @id @default(uuid()) @db.Uuid
  code         String       @unique
  label        String       @unique
  pluralLabel  String       @unique
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  ingredients  Ingredient[]

  @@index([label])
}

model GeneralIngredient {
  id          String       @id @default(uuid()) @db.Uuid
  name        String       @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  ingredients Ingredient[]
}

model RecipeType {
  id        String             @id @default(uuid()) @db.Uuid
  name      String             @unique
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  recipes   RecipeTypeOnRecipe[]
}

model RecipeTypeOnRecipe {
  recipeId     String     @db.Uuid
  recipeTypeId String     @db.Uuid

  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeType   RecipeType @relation(fields: [recipeTypeId], references: [id], onDelete: Cascade)

  createdAt    DateTime   @default(now())

  @@id([recipeId, recipeTypeId])
  @@index([recipeTypeId])
}

model RecipeImage {
  id          String   @id @default(uuid()) @db.Uuid

  recipeId    String   @db.Uuid
  recipe      Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  key         String   @unique
  url         String
  alt         String
  contentType String?
  sizeBytes   Int?
  width       Int?
  height      Int?

  isCover     Boolean  @default(false)
  order       Int      @default(0)

  createdAt   DateTime @default(now())

  @@index([recipeId])
  @@index([recipeId, isCover])
  @@index([recipeId, order])
}

model Utensil {
  id        String          @id @default(uuid()) @db.Uuid
  name      String          @unique
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  recipes   UtensilOnRecipe[]
}

model UtensilOnRecipe {
  recipeId  String   @db.Uuid
  utensilId String   @db.Uuid

  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  utensil   Utensil  @relation(fields: [utensilId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([recipeId, utensilId])
  @@index([utensilId])
}

model Comment {
  id        String   @id @default(uuid()) @db.Uuid

  recipeId  String   @db.Uuid
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  userId    String?  @db.Uuid
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  rating    Int?
  title     String?
  body      String   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([recipeId])
  @@index([userId])
}

enum RecipeDifficulty {
  EASY
  EASY_MEDIUM
  MEDIUM
  MEDIUM_HARD
  HARD
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  name          String
  email         String    @db.VarChar(320)
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  recipes       Recipe[]
  comments      Comment[]

  @@unique([email])
  @@index([createdAt])
  @@map("user")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, expiresAt])
  @@index([expiresAt])
  @@map("session")
}

model Account {
  id                    String   @id @default(uuid()) @db.Uuid
  accountId             String
  providerId            String
  userId                String   @db.Uuid
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
  @@index([providerId])
  @@map("account")
}

model Verification {
  id         String   @id @default(uuid()) @db.Uuid
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@index([expiresAt])
  @@map("verification")
}
